# Application
APP_ENV=production
DEBUG=false
TIMEZONE=Europe/Istanbul

# Ports (home-server host mapping)
BACKEND_PORT=8000
FRONTEND_PORT=3000
WHATSAPP_PORT=3001
OLLAMA_PORT=11434

# Frontend → Backend (browser-accessible URL of your home server)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Where Docker stores persistent data. On the CI/CD runner set this to an
# ABSOLUTE path OUTSIDE the repo checkout (örn. /home/berat/med-data) so the
# git workspace never contains root-owned container files.
# DATA_ROOT=/home/berat/med-data

# Reminders: WhatsApp mesajı 1 kere gönderilir; alındı işaretlenene kadar
# push her 5 dakikada bir (koda sabit) REMINDER_MAX_RETRIES kez tekrar edilir,
# sonra 'missed' işaretlenir.
REMINDER_MAX_RETRIES=3

# Optional: notify admin on missed medication
ADMIN_PHONE=

# Push notifications (ntfy → mobile app). Self-hosted, no API key.
PUSH_ENABLED=true
NTFY_PORT=8080
NTFY_TOPIC=medication-reminders
# Set only if you enable ntfy auth (internet exposure):
# NTFY_TOKEN=

# AI
AI_PROVIDER=openrouter
OLLAMA_MODEL=llama3.2
OPENROUTER_API_KEY=
# ÜCRETSİZ model — sonu ":free" ile bitmeli, asla fatura çıkmaz:
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
OPENROUTER_FREE_ONLY=true

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
